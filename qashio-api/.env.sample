# Copy this file to .env and fill in your values.
# cp .env.sample .env

# User ID that owns seed/backfill data (see src/database/seed.ts).
# Set to a valid user UUID to run the seed; leave empty to skip seeding.
SEED_USER_ID=

# Database: DATABASE_URL is used first; DB_* are fallback if DATABASE_URL is unset.
DATABASE_URL=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

# JWT secret for auth tokens (use a strong secret in production).
JWT_SECRET=

# Server port.
PORT=

# Kafka broker (optional, for transaction events).
KAFKA_BROKER=

# Node environment: development | production.
NODE_ENV=
